#!/bin/bash -e

source ${STI_SCRIPTS_PATH}/assemble

NEXTCLOUD_VERSION=32.0.6

curl -fsSL -o nextcloud.tar.bz2 "https://github.com/nextcloud-releases/server/releases/download/v${NEXTCLOUD_VERSION}/nextcloud-${NEXTCLOUD_VERSION}.tar.bz2";
tar -xjf nextcloud.tar.bz2 -C ${HOME} --strip-components=1
rm nextcloud.tar.bz2

fix-permissions ${HOME}/
fix-permissions /var/www/

mkdir -p ${HOME}/data
mkdir ${HOME}/custom_apps
rm -fR ${HOME}/nginx-cfg

chmod +x ${HOME}/occ

mv autoconfig/* config/
rmdir autoconfig
